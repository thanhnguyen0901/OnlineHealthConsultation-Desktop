<Window x:Class="OnlineHealthConsultation.Desktop.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Online Health Consultation - Doctor Workstation"
        Width="1180"
        Height="760"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="{StaticResource AppBackground}">
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBackground}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Doctor Workstation" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ApiBaseUrl}" Foreground="#CCFFFFFF" Margin="0,4,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding DoctorName}" Foreground="White" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Left" Background="White" Width="220" Padding="16">
            <StackPanel>
                <Button x:Name="ShowDashboard" Content="Dashboard" Style="{StaticResource NavButton}" />
                <Button x:Name="ShowAppointments" Content="Appointments" Style="{StaticResource NavButton}" />
                <Button x:Name="ShowQuestions" Content="Questions" Style="{StaticResource NavButton}" />
            </StackPanel>
        </Border>

        <ContentControl x:Name="ActiveItem" Margin="24" />
    </DockPanel>
</Window>
