<Window x:Class="OnlineHealthConsultation.Desktop.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Doctor Desktop Login"
        Width="460"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource AppBackground}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Doctor Workstation" Style="{StaticResource TitleText}" />
            <TextBlock Text="WPF/C# client calling the shared backend REST API"
                       Style="{StaticResource MutedText}"
                       Margin="0,8,0,24" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Panel}">
            <StackPanel>
                <TextBlock Text="API Base URL" Style="{StaticResource LabelText}" />
                <TextBox x:Name="ApiBaseUrl" Margin="0,6,0,16" />

                <TextBlock Text="Doctor Email" Style="{StaticResource LabelText}" />
                <TextBox x:Name="Email" Margin="0,6,0,16" />

                <TextBlock Text="Password" Style="{StaticResource LabelText}" />
                <TextBox x:Name="Password" Margin="0,6,0,22" />

                <Button x:Name="Login"
                        Content="Sign In"
                        Style="{StaticResource PrimaryButton}"
                        Height="42" />

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SuccessText}" Margin="0,18,0,0" />
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}" Margin="0,18,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
