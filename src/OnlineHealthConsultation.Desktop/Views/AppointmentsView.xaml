<UserControl x:Class="OnlineHealthConsultation.Desktop.Views.AppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Appointments" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Manage doctor appointment workflow from the desktop client." Style="{StaticResource MutedText}" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      x:Name="StatusFilter"
                      ItemsSource="{Binding StatusFilters}"
                      SelectedItem="{Binding StatusFilter}"
                      Margin="12,0"
                      VerticalAlignment="Center" />
            <Button Grid.Column="2" x:Name="Load" Content="Refresh" Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="3" x:Name="ConfirmSelected" Content="Confirm" Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="4" x:Name="CompleteSelected" Content="Complete" Style="{StaticResource PrimaryButtonSmall}" />
        </Grid>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}" Margin="0,12,0,0" TextWrapping="Wrap" />

        <DataGrid ItemsSource="{Binding Appointments}"
                  SelectedItem="{Binding SelectedAppointment}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding ScheduledAtText}" Width="150" />
                <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="180" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="160" />
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" />
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
