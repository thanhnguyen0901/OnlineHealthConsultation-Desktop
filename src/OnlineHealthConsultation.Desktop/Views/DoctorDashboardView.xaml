<UserControl x:Class="OnlineHealthConsultation.Desktop.Views.DoctorDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Dashboard" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding DoctorName}" Style="{StaticResource MutedText}" />
            </StackPanel>
            <Button Grid.Column="1" x:Name="Load" Content="Refresh" Style="{StaticResource SecondaryButton}" />
        </Grid>

        <UniformGrid Columns="3" Margin="0,0,0,22">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Appointments" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding AppointmentCount}" Style="{StaticResource StatNumber}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Pending Questions" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding PendingQuestionCount}" Style="{StaticResource StatNumber}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Specialty" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding SpecialtyText}" FontSize="20" FontWeight="SemiBold" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Style="{StaticResource Panel}">
            <StackPanel>
                <TextBlock Text="Profile Summary" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Profile.Bio}" Margin="0,10,0,0" TextWrapping="Wrap" />
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}" Margin="0,16,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
