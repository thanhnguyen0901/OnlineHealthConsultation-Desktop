<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackground" Color="#F4F7FA" />
    <SolidColorBrush x:Key="HeaderBackground" Color="#174D63" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0E7490" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#155E75" />
    <SolidColorBrush x:Key="MutedBrush" Color="#64748B" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8E1E8" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#B91C1C" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#047857" />

    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#102A43" />
    </Style>

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#102A43" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#334155" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ErrorText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SuccessText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="StatNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#0F172A" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style
        x:Key="StatCard"
        BasedOn="{StaticResource Panel}"
        TargetType="Border">
        <Setter Property="Margin" Value="0,0,14,0" />
        <Setter Property="MinHeight" Value="120" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style
        x:Key="PrimaryButtonSmall"
        BasedOn="{StaticResource PrimaryButton}"
        TargetType="Button">
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="MinWidth" Value="110" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="#0F172A" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style
        x:Key="NavButton"
        BasedOn="{StaticResource SecondaryButton}"
        TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="14,11" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowHeight" Value="42" />
        <Setter Property="FontSize" Value="14" />
    </Style>
</ResourceDictionary>
