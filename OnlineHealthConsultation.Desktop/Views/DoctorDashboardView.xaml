<UserControl
    x:Class="OnlineHealthConsultation.Desktop.Views.DoctorDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleText}" Text="Tổng quan" />
                <TextBlock Style="{StaticResource MutedText}" Text="{Binding DoctorName}" />
            </StackPanel>
            <Button
                x:Name="Load"
                Grid.Column="1"
                Content="Làm mới"
                Style="{StaticResource SecondaryButton}" />
        </Grid>

        <UniformGrid Margin="0,0,0,22" Columns="3">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelText}" Text="Lịch hẹn" />
                    <TextBlock Style="{StaticResource StatNumber}" Text="{Binding AppointmentCount}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelText}" Text="Câu hỏi chưa trả lời" />
                    <TextBlock Style="{StaticResource StatNumber}" Text="{Binding PendingQuestionCount}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelText}" Text="Chuyên khoa" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding SpecialtyText}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Style="{StaticResource Panel}">
            <StackPanel>
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Thông tin cá nhân" />
                <TextBlock
                    Margin="0,10,0,0"
                    Text="{Binding Profile.Bio}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,16,0,0"
                    Style="{StaticResource ErrorText}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
