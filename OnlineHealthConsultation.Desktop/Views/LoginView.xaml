<Window
    x:Class="OnlineHealthConsultation.Desktop.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Đăng nhập - Bác sĩ"
    Width="1180"
    Height="760"
    WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource AppBackground}">
        <Border Style="{StaticResource Panel}" 
                Width="440" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Padding="32,28">
            <StackPanel>
                <TextBlock Style="{StaticResource TitleText}" Text="Kênh Bác sĩ" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock
                    Margin="0,0,0,28"
                    Style="{StaticResource MutedText}"
                    Text="Hệ thống Bác sĩ trực tuyến"
                    HorizontalAlignment="Center" />

                <TextBlock Style="{StaticResource LabelText}" Text="Email Bác sĩ" />
                <TextBox x:Name="Email" Margin="0,6,0,16" />

                <TextBlock Style="{StaticResource LabelText}" Text="Mật khẩu" />
                <TextBox x:Name="Password" Margin="0,6,0,22" />

                <Button
                    x:Name="Login"
                    Height="42"
                    Content="Đăng nhập"
                    Style="{StaticResource PrimaryButton}" />

                <TextBlock
                    Margin="0,18,0,0"
                    Style="{StaticResource SuccessText}"
                    Text="{Binding StatusMessage}"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Margin="0,18,0,0"
                    Style="{StaticResource ErrorText}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
