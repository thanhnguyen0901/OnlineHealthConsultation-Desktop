<UserControl
    x:Class="OnlineHealthConsultation.Desktop.Views.QuestionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleText}" Text="Question Inbox" />
                <TextBlock Style="{StaticResource MutedText}" Text="Answer patient health questions from the shared backend service." />
            </StackPanel>
            <Button
                x:Name="Load"
                Grid.Column="1"
                Content="Refresh"
                Style="{StaticResource SecondaryButton}" />
            <Button
                x:Name="AnswerSelected"
                Grid.Column="2"
                Content="Submit Answer"
                Style="{StaticResource PrimaryButtonSmall}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding Questions}"
                SelectedItem="{Binding SelectedQuestion}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="140"
                        Binding="{Binding CreatedAtText}"
                        Header="Created" />
                    <DataGridTextColumn
                        Width="160"
                        Binding="{Binding PatientName}"
                        Header="Patient" />
                    <DataGridTextColumn
                        Width="110"
                        Binding="{Binding Status}"
                        Header="Status" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Content}"
                        Header="Question" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Selected Question" />
                    <TextBlock
                        Margin="0,10,0,18"
                        Text="{Binding SelectedQuestion.Content}"
                        TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource LabelText}" Text="Answer" />
                    <TextBox
                        x:Name="AnswerContent"
                        MinHeight="170"
                        Margin="0,6,0,0"
                        AcceptsReturn="True"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource SuccessText}" Text="{Binding StatusMessage}" />
            <TextBlock
                Style="{StaticResource ErrorText}"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
