<UserControl
    x:Class="OnlineHealthConsultation.Desktop.Views.AppointmentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <Grid Margin="0,0,0,18" DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleText}" Text="Danh sách Lịch hẹn" />
                <TextBlock Style="{StaticResource MutedText}" Text="Quản lý quy trình lịch hẹn khám bệnh của bác sĩ." />
            </StackPanel>
            <ComboBox
                x:Name="StatusFilter"
                Grid.Column="1"
                Margin="12,0"
                VerticalAlignment="Center"
                ItemsSource="{Binding StatusFilters}"
                SelectedItem="{Binding StatusFilter}" />
            <Button
                x:Name="Load"
                Grid.Column="2"
                Content="Làm mới"
                Style="{StaticResource SecondaryButton}" />
            <Button
                x:Name="ConfirmSelected"
                Grid.Column="3"
                Content="Xác nhận"
                Style="{StaticResource SecondaryButton}" />
            <Button
                x:Name="CompleteSelected"
                Grid.Column="4"
                Content="Hoàn thành"
                Style="{StaticResource PrimaryButtonSmall}" />
        </Grid>

        <TextBlock
            Margin="0,12,0,0"
            DockPanel.Dock="Bottom"
            Style="{StaticResource ErrorText}"
            Text="{Binding ErrorMessage}"
            TextWrapping="Wrap" />

        <DataGrid
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            GridLinesVisibility="None"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding Appointments}"
            SelectedItem="{Binding SelectedAppointment}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding ScheduledAtText}"
                    Header="Thời gian" />
                <DataGridTextColumn
                    Width="180"
                    Binding="{Binding PatientName}"
                    Header="Bệnh nhân" />
                <DataGridTextColumn
                    Width="160"
                    Binding="{Binding StatusText}"
                    Header="Trạng thái" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Reason}"
                    Header="Lý do khám" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Notes}"
                    Header="Ghi chú" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
