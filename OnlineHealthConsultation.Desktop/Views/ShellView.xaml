<Window
    x:Class="OnlineHealthConsultation.Desktop.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tư vấn Sức khỏe Trực tuyến - Hệ thống Bác sĩ"
    Width="1180"
    Height="760"
    WindowStartupLocation="CenterScreen">
    <DockPanel Background="{StaticResource AppBackground}">
        <Border
            Padding="24,16"
            Background="{StaticResource HeaderBackground}"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Hệ thống Bác sĩ" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="#CCFFFFFF"
                        Text="{Binding ApiBaseUrl}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#CCFFFFFF" Text="Bác sĩ: " VerticalAlignment="Center" FontSize="14" />
                    <TextBlock FontWeight="SemiBold" Foreground="White" Text="{Binding DoctorName}" VerticalAlignment="Center" FontSize="14" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Width="220"
            Padding="16"
            Background="White"
            DockPanel.Dock="Left">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0">
                    <RadioButton
                        x:Name="ShowDashboard"
                        Content="Tổng quan"
                        IsChecked="{Binding IsDashboardActive, Mode=OneWay}"
                        Style="{StaticResource NavRadioButton}" />
                    <RadioButton
                        x:Name="ShowAppointments"
                        Content="Lịch hẹn"
                        IsChecked="{Binding IsAppointmentsActive, Mode=OneWay}"
                        Style="{StaticResource NavRadioButton}" />
                    <RadioButton
                        x:Name="ShowQuestions"
                        Content="Hỏi đáp"
                        IsChecked="{Binding IsQuestionsActive, Mode=OneWay}"
                        Style="{StaticResource NavRadioButton}" />
                </StackPanel>

                <Button
                    x:Name="Logout"
                    Grid.Row="1"
                    Content="Đăng xuất"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0" />
            </Grid>
        </Border>

        <ContentControl x:Name="ActiveItem" Margin="24" />
    </DockPanel>
</Window>
